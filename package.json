{
  "name": "home-workout-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first camera-based home workout tracker.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @home-workout/desktop",
    "sync:mediapipe-assets": "node scripts/sync-mediapipe-assets.mjs",
    "build": "npm run build --workspaces --if-present",
    "clean": "rm -rf apps/*/dist apps/*/dist-electron packages/*/dist apps/*/*.tsbuildinfo packages/*/*.tsbuildinfo coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.eslint.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^22.15.17",
    "eslint": "^9.27.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  }
}
