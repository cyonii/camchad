{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "jsx": "react-jsx",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "target": "ES2022",
    "baseUrl": "../..",
    "paths": {
      "@home-activity/pose-core": ["packages/pose-core/src/index.ts"],
      "@home-activity/movement-core": ["packages/movement-core/src/index.ts"],
      "@home-activity/activity-history": ["packages/activity-history/src/index.ts"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [
    {
      "path": "../pose-core"
    },
    {
      "path": "../movement-core"
    },
    {
      "path": "../activity-history"
    }
  ]
}
